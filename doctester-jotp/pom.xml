<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <artifactId>doctester-jotp</artifactId>
    <packaging>jar</packaging>
    <name>DocTester JOTP — Java Open Telecom Protocol Doctests</name>
    <description>
        DocTester doctests for all JOTP (Java Open Telecom Protocol) primitives and
        reactive messaging patterns sourced from the jotp git submodule.
    </description>

    <parent>
        <groupId>org.r10r</groupId>
        <artifactId>doctester</artifactId>
        <version>1.1.12-SNAPSHOT</version>
    </parent>

    <dependencies>

        <!-- Core DocTester library under test -->
        <dependency>
            <groupId>org.r10r</groupId>
            <artifactId>doctester-core</artifactId>
            <version>${project.parent.version}</version>
        </dependency>

        <!-- JUnit 4 (same as doctester-core uses) -->
        <dependency>
            <groupId>junit</groupId>
            <artifactId>junit</artifactId>
            <version>4.12</version>
            <scope>test</scope>
        </dependency>

        <!-- Logging for tests -->
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-simple</artifactId>
            <version>1.7.12</version>
            <scope>test</scope>
        </dependency>

        <!--
            doctester-core's Apache HttpClient uses commons-logging at runtime.
            jcl-over-slf4j provides LogFactory so ClassNotFoundException is avoided
            without pulling in actual commons-logging.
        -->
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>jcl-over-slf4j</artifactId>
            <version>1.7.12</version>
            <scope>test</scope>
        </dependency>

    </dependencies>

    <build>
        <plugins>

            <!--
                Pull in all JOTP source files from the git submodule as an additional
                compile-time source root. By excluding module-info.java we compile the
                org.acme classes into the unnamed module alongside the doctests, giving
                full access to every JOTP primitive and pattern without JPMS complexity.
            -->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>build-helper-maven-plugin</artifactId>
                <version>3.6.0</version>
                <executions>
                    <execution>
                        <id>add-jotp-source</id>
                        <phase>generate-sources</phase>
                        <goals>
                            <goal>add-source</goal>
                        </goals>
                        <configuration>
                            <sources>
                                <source>${project.basedir}/../jotp/src/main/java</source>
                            </sources>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!--
                Compiler: Java 25 + preview.
                useModulePath=false forces all dependencies (including doctester-core)
                onto the classpath rather than the module-path, preventing the JPMS
                module-info.java in the jotp submodule source from hijacking the build
                into named-module mode where classpath jars become invisible.
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <configuration>
                    <release>25</release>
                    <compilerArgs>
                        <arg>--enable-preview</arg>
                    </compilerArgs>
                    <enablePreview>true</enablePreview>
                    <useModulePath>false</useModulePath>
                    <excludes>
                        <exclude>module-info.java</exclude>
                    </excludes>
                    <testExcludes>
                        <testExclude>module-info.java</testExclude>
                    </testExcludes>
                </configuration>
            </plugin>

            <!-- Surefire: run with enable-preview on Java 25 -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <configuration>
                    <argLine>--enable-preview</argLine>
                </configuration>
            </plugin>

        </plugins>
    </build>

</project>
