{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(mvnd:*)",
      "Bash(mvn:*)",
      "Bash(java:*)",
      "Bash(javac:*)",
      "Bash(git:*)"
    ]
  }
}
