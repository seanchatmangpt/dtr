package io.github.seanchatmangpt.dtr.jotp;

import org.junit.Test;
import io.github.seanchatmangpt.dtr.DtrTest;

/**
 * DTR overview of all jotp OTP primitives — generated from {@code jotp-api.ttl}.
 *
 * <p>jotp brings Erlang/OTP fault-tolerance patterns to Java 26 virtual threads.
 * This test documents every primitive at a glance and serves as the table of
 * contents for the per-category deep-dive tests.
 */
public class JotpOverviewDocTest extends DtrTest {

    @Test
    public void testJotpPrimitivesOverview() {
        sayNextSection("jotp — Java OTP Primitives Overview");
        say("jotp implements Erlang/OTP's battle-tested fault-tolerance patterns on top of "
                + "Java 26 virtual threads (JEP 444). The library provides "
                + "<strong>{{ sparql_results | length }} primitives</strong> grouped into "
                + "five categories: core processes, supervision, state management, "
                + "error handling, and runtime services.");

        say("The table below lists every primitive, its Java generic signature, "
                + "and a one-line description. Each category has a dedicated DocTest "
                + "with full method-level coverage.");

        String[][] overview = new String[{{ sparql_results | length }} + 1][4];
        overview[0] = new String[]{"Primitive", "Category", "Java Class", "Description"};
        {% for row in sparql_results %}
        overview[{{ loop.index }}] = new String[]{
            "{{ row["?name"] }}",
            "{{ row["?category"] }}",
            "<code>{{ row["?javaClass"] | replace(from="io.github.seanchatmangpt.jotp.", to="jotp.") }}</code>",
            "{{ row["?description"] }}"
        };
        {% endfor %}
        sayTable(overview);

        sayNote("Each primitive is documented in detail in its category DocTest: "
                + "CoreProcessDocTest, SupervisorDocTest, StateManagementDocTest, "
                + "ErrorHandlingDocTest, RuntimeServicesDocTest.");
    }

    @Test
    public void testJotpCategorySummary() {
        sayNextSection("Category Summary");
        say("jotp primitives are grouped by responsibility:");

        String[][] categories = new String[][]{
            {"Category", "Primitives", "Purpose"},
            {"core",       "Proc, ProcRef, ProcMonitor, ProcLink, ProcTimer",
                           "Process lifecycle, references, links, and timed messages"},
            {"supervision","Supervisor",
                           "Fault-recovery trees with ONE_FOR_ONE / ONE_FOR_ALL / REST_FOR_ONE"},
            {"state",      "StateMachine, EventManager",
                           "Sealed-type state transitions and typed event broadcasting"},
            {"error",      "Result, Parallel",
                           "Railway-oriented error handling and structured concurrency"},
            {"runtime",    "ProcRegistry, ProcSys, ProcLib",
                           "Named lookup, system introspection, and application startup"}
        };
        sayTable(categories);

        {% for row in sparql_results %}{% if row["?jepNote"] %}
        sayNote("{{ row["?name"] }}: {{ row["?jepNote"] }}");
        {% endif %}{% endfor %}
    }
}
