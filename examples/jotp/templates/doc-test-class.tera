 * License for the specific language governing permissions and limitations under
 * the License.
 *
 * Generated by ggen from ontology/jotp-api.ttl — do not edit by hand.
 * Re-generate: cd jotp && ggen sync
 */
package io.github.seanchatmangpt.dtr.jotp;

import org.junit.Test;
import io.github.seanchatmangpt.dtr.DtrTest;

/**
 * DTR documentation for jotp
 * {% set seen_names = [] %}{% for row in sparql_results %}{% if row["?name"] not in seen_names %}{% set_global seen_names = seen_names | concat(with=row["?name"]) %}{{ row["?name"] }}{% if not loop.last %}, {% endif %}{% endif %}{% endfor %}
 * primitives — generated from {@code jotp-api.ttl}.
 *
 * <p>Each {@code @Test} method documents one primitive:
 * <ul>
 {% set seen = [] %}{% for row in sparql_results %}{% if row["?name"] not in seen %}{% set_global seen = seen | concat(with=row["?name"]) %}
 *   <li>{@code {{ row["?name"] }}{% if row["?javaGenerics"] %}{{ row["?javaGenerics"] }}{% endif %}} — {{ row["?description"] }}</li>
 {% endif %}{% endfor %}
 * </ul>
 */
public class {% set first = sparql_results | first %}{% set cat = first["?category"] | capitalize %}{% if cat == "Core" %}CoreProcess{% elif cat == "Supervision" %}Supervisor{% elif cat == "State" %}StateManagement{% elif cat == "Error" %}ErrorHandling{% elif cat == "Runtime" %}RuntimeServices{% else %}{{ cat }}{% endif %}DocTest extends DtrTest {

    {% set seen_names = [] %}
    {% for row in sparql_results %}
    {% if row["?name"] not in seen_names %}
    {% set_global seen_names = seen_names | concat(with=row["?name"]) %}

    // ─────────────────────────────────────────────────────────────────────────
    // {{ row["?name"] }}{% if row["?javaGenerics"] %}{{ row["?javaGenerics"] }}{% endif %}
    // ─────────────────────────────────────────────────────────────────────────

    @Test
    public void test{{ row["?name"] }}Overview() {
        sayNextSection("{{ row["?name"] }}{% if row["?javaGenerics"] %}{{ row["?javaGenerics"] }}{% endif %} — {{ row["?description"] }}");
        say("<code>{{ row["?name"] }}{% if row["?javaGenerics"] %}{{ row["?javaGenerics"] }}{% endif %}</code> is "
                + "a jotp primitive implemented in "
                + "<code>{{ row["?javaClass"] }}</code>.");

        // ── Method API table ─────────────────────────────────────────────────
        // Collect all method rows for this primitive and build a sayTable call.
        {% set method_rows = [] %}
        {% for m in sparql_results %}
        {% if m["?name"] == row["?name"] and m["?methodName"] %}
        {% set_global method_rows = method_rows | concat(with=m) %}
        {% endif %}
        {% endfor %}
        {% if method_rows %}
        String[][] methods = new String[{{ method_rows | length }} + 1][3];
        methods[0] = new String[]{"Method", "Signature", "Description"};
        {% for m in method_rows %}
        methods[{{ loop.index }}] = new String[]{
            "<code>{{ m["?methodName"] }}</code>",
            "<code>{{ m["?methodSig"] }}</code>",
            "{{ m["?methodDesc"] }}"
        };
        {% endfor %}
        sayTable(methods);
        {% else %}
        sayNote("No public methods extracted from the ontology for this primitive.");
        {% endif %}

        // TODO: add sayAndAssertThat assertions once jotp is a Maven dependency.
        // Example:
        //   var proc = new {{ row["?name"] }}(...);
        //   sayAndAssertThat("...", actual, is(expected));
        sayNote("Add <code>sayAndAssertThat</code> assertions after importing jotp as a dependency.");
    }
    {% endif %}
    {% endfor %}
}
